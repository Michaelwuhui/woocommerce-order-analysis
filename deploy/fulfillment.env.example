# Keep this file outside the repository in production:
# /etc/woo-analysis/fulfillment.env (root:root, mode 0600)
WMS_SALT=
WMS_BASE_URL=http://cod.kuasuda.com/apicall

# The supplier currently documents plain HTTP. Leave disabled unless the
# security exception has been explicitly accepted for this integration.
WMS_ALLOW_INSECURE_HTTP=0

# Independent token for a future supplier callback; do not reuse WMS_SALT.
WMS_WEBHOOK_TOKEN=
